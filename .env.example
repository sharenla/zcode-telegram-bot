# ===== 必填 =====

# Telegram Bot Token(从 @BotFather 获取)
TELEGRAM_BOT_TOKEN=

# 允许使用的 Telegram user id,逗号分隔
# 获取方式:私聊 @userinfobot,它会回复你的 user id
# 可填多个:123456789,987654321
ALLOWED_USERS=

# 允许使用的 Telegram 群组 id(负数,逗号分隔)
# 群内任何人 @bot 都可用(共享一个 ZCode session)
# 群 id 获取方式:把 bot 拉进群后,在群里 /id 或用 @userinfobot
# 可填多个:-100123,-100456
ALLOWED_CHATS=

# ZCode Agent 工作目录(agent 只能操作这个目录下的文件,沙箱边界)
APPROVED_DIRECTORY=/path/to/your/project

# ===== 可选 =====

# ZCode CLI 路径(留空则自动定位:PATH > App bundle)
# ZCODE_CLI_PATH=/Applications/ZCode.app/Contents/Resources/glm/zcode.cjs

# 单次调用超时(秒)
# ZCODE_TIMEOUT=600

# Telegram 单条消息最大长度
# MAX_MESSAGE_LENGTH=4096

# 会话存储路径
# SESSION_DB_PATH=data/sessions.json

# ===== app-server 同步(可选,高级)=====

# 后端模式:1=app-server(流式 + 双向同步,默认);0=--prompt 回退
# USE_APP_SERVER=1

# session 工作区(默认同 APPROVED_DIRECTORY)
# WORKSPACE_PATH=/path/to/your/project

# TUI→bot 方向轮询间隔(秒,默认 1.5)
# POLL_INTERVAL=1.5

# 单个 turn 最长等待秒数(默认 600)
# APP_SERVER_TURN_TIMEOUT=600

# ZCode 权限模式(默认 build,写操作/命令需 Telegram 审批)
# build = 写操作需审批(推荐);yolo = 全自动无确认;plan = 只读;edit = 自动编辑
# SESSION_MODE=build
